{
  "name": "@sirosfoundation/wallet-companion",
  "version": "0.0.0",
  "author": "SIROS Foundation",
  "license": "BSD-2-Clause",
  "description": "A cross-browser companion extension that intercepts W3C Digital Credentials API calls, enabling users to select from multiple digital identity wallet providers.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "watch": "WATCH=true BROWSER=chrome tsx vite.ts",
    "watch:chrome": "WATCH=true BROWSER=chrome tsx vite.ts",
    "watch:firefox": "WATCH=true BROWSER=firefox tsx vite.ts",
    "watch:safari": "WATCH=true BROWSER=safari tsx vite.ts",
    "build": "pnpm build:chrome && pnpm build:firefox && pnpm build:safari",
    "build:chrome": "BROWSER=chrome tsx vite.ts",
    "build:firefox": "BROWSER=firefox tsx vite.ts",
    "build:safari": "BROWSER=safari tsx vite.ts",
    "dev:firefox": "cd firefox && web-ext run",
    "package:chrome": "cd dist/chrome && zip -r ../chrome-extension.zip . -x '*.git*' -x 'README.md'",
    "package:firefox": "cd dist/firefox && zip -r ../firefox-extension.xpi . -x '*.git*' -x 'README.md'",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm build:chrome && pnpm test:e2e",
    "test:server": "tsx tests/support/server.ts"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "safari-extension",
    "api-interceptor",
    "webextension"
  ],
  "dependencies": {
    "lucide": "^1.16.0",
    "@fontsource/inter": "^5.2.8",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.42",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.0.4",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "web-ext": "^10.2.0",
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "packageManager": "pnpm@10.4.0"
}
